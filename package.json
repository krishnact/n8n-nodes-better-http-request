{
  "name": "n8n-nodes-better-http-request",
  "version": "0.3.3",
  "description": "An enhanced HTTP Request node for n8n with retry-only-failed-items support",
  "license": "MIT",
  "keywords": [
    "n8n-community-node-package"
  ],
  "main": "dist/nodes/BetterHttpRequest/BetterHttpRequest.node.js",
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');fs.mkdirSync('dist/nodes/BetterHttpRequest',{recursive:true});fs.copyFileSync('nodes/BetterHttpRequest/betterhttp.svg','dist/nodes/BetterHttpRequest/betterhttp.svg')\"",
    "test": "jest --forceExit --detectOpenHandles"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/AntonyDalmiere/n8n-nodes-better-http-request"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "nodes": [
      "dist/nodes/BetterHttpRequest/BetterHttpRequest.node.js"
    ]
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^18.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "~5.5.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "dependencies": {
    "lodash": "^4.17.21"
  }
}
